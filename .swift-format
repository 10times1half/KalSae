{
  "fileScopedDeclarationPrivacy" : {
    "accessLevel" : "internal"
  },
  "indentation" : {
    "spaces" : 4
  },
  "lineLength" : 120,
  "maximumBlankLines" : 1,
  "multilineStringIndentationRules" : [
    {
      "baseIndentationLevel" : "sourcefile"
    }
  ],
  "noAccessLevelOnCaseDeclarations" : false,
  "prioritizeKeepingFunctionOutputTogether" : false,
  "respectsExistingLineBreaks" : true,
  "rules" : {
    "AllPublicDeclarationsHaveDocumentation" : false,
    "AlwaysUseLowerCamelCase" : true,
    "AmbiguousTrailingClosureOverload" : true,
    "BeginDocumentationComments" : true,
    "BlankLineBetweenMembers" : {
      "allowedInitializations" : [],
      "ignoredDeclarations" : [],
      "ignoredIdentifiers" : []
    },
    "CaseIndentation" : true,
    "ClosingBraceWhitespace" : true,
    "ColonWhitespace" : true,
    "CommaWhitespace" : true,
    "ConsecutiveDeclarations" : false,
    "DontRepeatTypeInStaticProperties" : false,
    "DoWhilePosition" : true,
    "ElseOnSameLine" : false,
    "EmptyBraces" : true,
    "FullyIndentedQuotedStringLiterals" : false,
    "FunctionCallArgumentsOnSeparateLines" : false,
    "FunctionDefaultParameterLocation" : true,
    "IdentifierColonWhitespace" : true,
    "IfElseExhaustiveness" : false,
    "IfWhileOnSameLine" : true,
    "ImportsOnSeparateLines" : true,
    "IndentationWidth" : false,
    "LineLengthConfiguration" : false,
    "LineOnlyContainsComment" : true,
    "MultiLineComment" : true,
    "MultilineConditionalClosingBrace" : true,
    "MultilineFunctionChainCallChainFormatting" : false,
    "NeverForceUnwrap" : false,
    "NeverUseForceTry" : false,
    "NeverUseImplicitlyUnwrappedOptionals" : false,
    "NoAccessLevelOnCaseDeclarations" : true,
    "NoAssignmentInExpressions" : true,
    "NoBlockComments" : true,
    "NoCasesWithOnlyFallthrough" : true,
    "NoEmptyTrailingClosureParentheses" : true,
    "NoLabelsInCasePatterns" : true,
    "NoLeadingUnderscoresInCasePatterns" : false,
    "NoParensAroundConditions" : true,
    "NoVoidReturnOnFunctionSignature" : true,
    "ObjCBracketEmptyParentheses" : true,
    "OneVariableDeclarationPerLine" : true,
    "OnlyOneImportPerLine" : true,
    "OperatorWhitespace" : true,
    "ParenthesesAroundConditionals" : false,
    "PatternBindingKeywordSpacing" : true,
    "PrimaryAssociatedTypesInGenericConstraints" : false,
    "RedundantClosureParentheses" : true,
    "RedundantExtensionACL" : true,
    "RedundantFilescopeACL" : true,
    "RedundantInit" : true,
    "RedundantLetInPatternBinding" : true,
    "RedundantObjCAttribute" : true,
    "RedundantParenthesesAroundConditions" : true,
    "RedundantRawStringDelimiters" : true,
    "RedundantReturn" : true,
    "RedundantSelfInClosureCapture" : false,
    "RedundantSelfInMemberReference" : true,
    "RedundantTypeAnnotation" : true,
    "RedundantVoidReturnType" : true,
    "ReturnVoidInsteadOfNil" : false,
    "SelfBindingVariableName" : true,
    "SemicolonsCodingStyle" : true,
    "SingleLineComment" : true,
    "SortImports" : true,
    "SortSwitchCasesByTheirTypeNames" : false,
    "Space" : true,
    "SpaceAroundOperators" : true,
    "SpaceBeforeAndAfterBinaryOperators" : false,
    "SpaceBeforeBraces" : true,
    "SpaceBeforeComma" : false,
    "SpaceBeforeControlFlowKeyword" : true,
    "SpaceBeforeOpeningBrace" : true,
    "SpaceInsideBrackets" : true,
    "SpaceInsideGenerics" : false,
    "SpaceInsideParentheses" : false,
    "SpaceInsideSquareBrackets" : false,
    "SpaceSurroundingAttributeSpecifiers" : true,
    "StatementPosition" : true,
    "TrailingCommas" : true,
    "TrailingWhitespace" : true,
    "TypeNamesShouldBeCapitalized" : true,
    "UnnecessaryDesugaring" : true,
    "UnnecessaryIsolatedBypass" : false,
    "UseShorthandTypeNames" : true,
    "ValidateDocumentationComments" : false,
    "VoidReturnTypesInProtocols" : true,
    "WhitespaceAroundBraces" : true,
    "WhitespaceAroundBracketsAndGenerics" : false
  },
  "spacesAroundRangeFormationOperators" : false,
  "spacesInsideParentheses" : false,
  "tabWidth" : 4,
  "usesTabs" : false,
  "version" : 1
}
