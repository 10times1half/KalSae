{
  "swift.sourcekit-lsp.serverArguments": [
    "--exclude",
    "**/.continue/**",
    "**/*.md"
  ],

  "[markdown]": {
    "swift.sourcekit-lsp.enable": false,
    "editor.defaultFormatter": null
  },

  "swift.sourcekit-lsp.exclude": [
    "**/.continue/**",
    "**/*.md"
  ],

  "files.exclude": {
    "**/.continue": true
  },

  "search.exclude": {
    "**/.continue": true
  }
}