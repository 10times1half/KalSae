// swift-tools-version:6.0
import PackageDescription

let package = Package(
    name: "{{NAME}}",
    // SwiftPM의 `platforms:`는 Apple 플랫폼 최소 버전만 선언한다.
    // Windows 10 1809+ 와 Linux (GTK4 + WebKitGTK 6.0)는 자동 지원되며,
    // 이 줄은 그 두 OS에서의 빌드를 제한하지 않는다.
    //
    // iOS / Android 빌드는 `kalsae build --ios` 또는 `kalsae build --android`
    // 를 사용한다. iOS는 UIKit `@main` 진입점이, Android는 Activity 호스트가
    // 별도로 필요하다 — `Samples/KalsaeIOSSample/`, `Samples/KalsaeAndroidSample/`
    // 참고.
    platforms: [
        .macOS(.v14),
        .iOS(.v16),
    ],
    dependencies: [
        {{KALSAE_DEPENDENCY}}
    ],
    targets: [
        .executableTarget(
            name: "{{NAME}}",
            dependencies: [
        .product(name: "Kalsae", package: "kalsae"),
            ],
            path: "Sources/{{NAME}}",
            resources: [.copy("Resources")],
            swiftSettings: [
                .swiftLanguageMode(.v6),
                .enableUpcomingFeature("ExistentialAny"),
                .enableUpcomingFeature("InternalImportsByDefault"),
            ],
            linkerSettings: [
                // Windows: PE 서브시스템을 GUI 로 설정해 실행 시 콘솔 창이
                // 같이 뜨지 않게 한다. `wWinMain` 이 없는 Swift `@main` 이므로
                // CRT 시작 루틴을 일반 `mainCRTStartup` 으로 명시적으로 지정한다
                // (제거 시 LNK2019 unresolved external `wWinMain`).
                .unsafeFlags(
                    ["-Xlinker", "/SUBSYSTEM:WINDOWS",
                     "-Xlinker", "/ENTRY:mainCRTStartup"],
                    .when(platforms: [.windows])
                ),
            ]
        ),
    ]
)
