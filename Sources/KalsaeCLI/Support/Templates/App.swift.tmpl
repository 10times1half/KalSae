import Kalsae

// 이 진입점은 Windows / macOS / Linux 데스크톱 전용이다.
// iOS는 UIApplicationDelegate에서, Android는 Activity의 onCreate에서
// `KSApp.boot(...)`를 호출해야 한다. 호스트 통합 패턴은
// `Samples/KalsaeAndroidSample/` 및 `Samples/KalsaeIOSSample/` 참고.

// MARK: - Commands

struct HelloOut: Codable, Sendable { let message: String }

@KSCommand
func hello(name: String?) -> HelloOut {
    HelloOut(message: "Hello, \(name ?? "World")!")
}

// MARK: - Entry point

@main
struct App {
    static func main() async {
        do {
            try await run()
        } catch {
            print("Error: \(error)")
        }
    }

    @MainActor
    static func run() async throws {
        // `bootFromBundle` 이 다음 위치를 순서대로 탐색한다:
        //   1) 실행 파일 옆 `kalsae.json`   (kalsae build 의 일반 산출물)
        //   2) `.app/Contents/Resources`    (macOS 번들)
        //   3) SwiftPM 리소스 번들 (`.module`)  (개발 모드 `swift run`)
        //   4) Windows standalone PE RCDATA  (외부 파일이 없을 때)
        let app = try await KSApp.bootFromBundle(resourceBundle: .module) { registry in
            await _ksRegister_hello(into: registry)
        }
        _ = app.run()
    }
}
