<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{NAME}}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, sans-serif;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      height: 100vh;
      background: #0f0f0f; color: #f0f0f0;
      gap: 1.5rem;
    }
    h1 { font-size: 2.5rem; font-weight: 700; }
    button {
      padding: 0.6rem 2rem; font-size: 1rem;
      border-radius: 8px; border: 1px solid #555;
      background: #1e1e1e; color: #f0f0f0; cursor: pointer;
    }
    button:hover { background: #2e2e2e; }
    #output { font-size: 1rem; color: #aaa; min-height: 1.5em; }
  </style>
</head>
<body>
  <h1>{{NAME}}</h1>
  <button onclick="greet()">Say Hello</button>
  <p id="output"></p>
  <script>
    async function greet() {
      const result = await window.__KS_.invoke("hello", { name: "{{NAME}}" });
      document.getElementById("output").textContent = result.message;
    }
  </script>
</body>
</html>
