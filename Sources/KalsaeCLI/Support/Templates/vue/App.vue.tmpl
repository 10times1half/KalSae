<script setup lang="ts">
import { ref } from 'vue'

declare global {
  interface Window {
    __KS_: { invoke<T = unknown>(name: string, args?: unknown): Promise<T> }
  }
}

const msg = ref('')

async function greet() {
  const r = await window.__KS_.invoke<{ message: string }>('hello', {
    name: '{{NAME}}',
  })
  msg.value = r.message
}
</script>

<template>
  <main>
    <h1>{{NAME}}</h1>
    <button @click="greet">Say Hello</button>
    <p>{{ msg }}</p>
  </main>
</template>

<style scoped>
main {
  font-family: system-ui;
  padding: 32px;
}
</style>
