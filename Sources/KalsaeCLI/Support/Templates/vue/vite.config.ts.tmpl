import { defineConfig } from 'vite'
import vue from '@vitejs/plugin-vue'

// Kalsae: vite 출력은 프로젝트 루트의 `dist/` 에 만들고,
// `kalsae build` 가 SwiftPM 리소스 디렉터리로 증분 sync 한다.
export default defineConfig({
  plugins: [vue()],
  base: './',
  build: {
    outDir: 'dist',
    emptyOutDir: true,
  },
  server: {
    port: 5173,
    strictPort: true,
    watch: {
      // SwiftPM 빌드 산출물 / 동기화된 리소스는 vite HMR 대상이 아니다.
      // 무시하지 않으면 swift build 중 EBUSY/scandir 오류로 dev 서버가 종료된다.
      ignored: [
        '**/.build/**',
        '**/.swiftpm/**',
        '**/Sources/**/Resources/dist/**',
        '**/dist/**',
      ],
    },
  },
})
