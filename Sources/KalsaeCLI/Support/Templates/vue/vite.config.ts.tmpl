import { defineConfig } from 'vite'
import vue from '@vitejs/plugin-vue'

// Kalsae: vite 출력은 SwiftPM `.copy("Resources")` 가 패키징하도록
// `Sources/{{NAME}}/Resources/dist` 로 보낸다.
export default defineConfig({
  plugins: [vue()],
  base: './',
  build: {
    outDir: 'Sources/{{NAME}}/Resources/dist',
    emptyOutDir: true,
  },
  server: {
    port: 5173,
    strictPort: true,
    watch: {
      // SwiftPM 빌드 산출물은 vite HMR 대상이 아니다.
      // 무시하지 않으면 swift build 중 EBUSY/scandir 오류로 dev 서버가 종료된다.
      ignored: ['**/.build/**', '**/.swiftpm/**', '**/Sources/**/Resources/dist/**'],
    },
  },
})
