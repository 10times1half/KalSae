{
  "app": {
    "name": "kalsae Demo",
    "version": "0.1.0",
    "identifier": "dev.kalsae.demo",
    "description": "Sample kalsae application",
    "authors": ["kalsae Team"]
  },
  "build": {
    "frontendDist": "dist",
    "devServerURL": "http://localhost:5173",
    "devCommand": "npm run dev",
    "buildCommand": "npm run build"
  },
  "windows": [
    {
      "label": "main",
      "title": "kalsae Demo",
      "width": 1024,
      "height": 720,
      "minWidth": 640,
      "minHeight": 480,
      "resizable": true,
      "decorations": true,
      "transparent": false,
      "fullscreen": false,
      "visible": true,
      "center": true,
      "alwaysOnTop": false,
      "persistState": false
    }
  ],
  "security": {
    "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ks://localhost",
    "commandAllowlist": null,
    "fs": {
      "allow": ["$DOCS/kalsaeDemo/**"],
      "deny": []
    },
    "devtools": true,
    "http": {
      "allow": ["https://api.example.com/**"],
      "deny": [],
      "methods": ["GET", "POST"],
      "defaultHeaders": {}
    },
    "downloads": {
      "enabled": false,
      "defaultDirectory": "$DOCS/kalsaeDemo/Downloads",
      "promptUser": true
    },
    "navigation": {
      "allow": ["ks://localhost/**", "http://localhost:5173/**"],
      "openExternallyOnReject": true
    }
  },
  "autostart": {
    "args": ["--launched-by-os"]
  },
  "deepLink": {
    "schemes": ["kalsae-demo"],
    "autoRegisterOnLaunch": false
  },
  "tray": {
    "icon": "assets/tray.png",
    "tooltip": "kalsae Demo",
    "onLeftClick": "tray.toggleMain",
    "menu": [
      { "kind": "action", "id": "show", "label": "Show", "command": "window.showMain" },
      { "kind": "separator" },
      { "kind": "action", "id": "quit", "label": "Quit", "command": "app.quit" }
    ]
  },
  "menu": {
    "appMenu": [
      {
        "kind": "submenu", "id": "file", "label": "File",
        "submenu": [
          { "kind": "action", "id": "new", "label": "New", "accelerator": "CmdOrCtrl+N", "command": "file.new" },
          { "kind": "separator" },
          { "kind": "action", "id": "quit", "label": "Quit", "accelerator": "CmdOrCtrl+Q", "command": "app.quit" }
        ]
      }
    ]
  },
  "notifications": {
    "appUserModelID": "dev.kalsae.demo",
    "defaultIcon": "assets/icon.png"
  }
}
