{
  "app": {
    "name": "Kalsae Demo",
    "version": "0.1.0",
    "identifier": "dev.kalsae.demo",
    "description": "Sample Kalsae application",
    "authors": ["Kalsae Team"]
  },
  "build": {
    "frontendDist": "dist",
    "devServerURL": "http://localhost:5173",
    "devCommand": "npm run dev",
    "buildCommand": "npm run build",
    "stripSourceMaps": true,
    "stripExtensions": [],
    "bundleReport": true
  },
  "windows": [
    {
      "label": "main",
      "title": "Kalsae Demo",
      "width": 1024,
      "height": 720,
      "minWidth": 640,
      "minHeight": 480,
      "resizable": true,
      "decorations": true,
      "transparent": false,
      "fullscreen": false,
      "visible": true,
      "center": true,
      "alwaysOnTop": false,
      "persistState": false,
      "webview": {
        "preferences": {
          "developerExtrasEnabled": null,
          "javaScriptEnabled": true,
          "swipeNavigation": true,
          "fraudulentWebsiteWarning": true,
          "mediaAutoplay": "userGesture",
          "allowsInlineMediaPlayback": true,
          "hardwareAcceleration": "auto",
          "smoothScrolling": true
        },
        "platform": {
          "windows": {
            "additionalBrowserArguments": "--js-flags=--max-old-space-size=512",
            "language": "ko-KR",
            "allowSingleSignOn": false,
            "exclusiveUserDataFolderAccess": true,
            "trackingPrevention": "balanced"
          },
          "mac": {
            "limitNavigationsToAppBoundDomains": false,
            "suppressIncrementalRendering": false,
            "preferredContentMode": "recommended",
            "shareProcessPool": false
          },
          "linux": {
            "enableWebgl": true,
            "enableWebaudio": true
          }
        }
      }
    },
    {
      "label": "overlay",
      "title": "Transparent overlay (Windows-only, v0.3)",
      "width": 480,
      "height": 320,
      "resizable": true,
      "decorations": false,
      "transparent": true,
      "visible": false,
      "alwaysOnTop": true,
      "webview": { "backdropType": "mica" }
    }
  ],
  "security": {
    "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ks://localhost",
    "commandAllowlist": ["greet", "app.*", "window.*", "fs.*"],
    "fs": {
      "allow": ["$DOCS/kalsaeDemo/**"],
      "deny": []
    },
    "devtools": true,
    "http": {
      "allow": ["https://api.example.com/**"],
      "deny": [],
      "methods": ["GET", "POST"],
      "defaultHeaders": {}
    },
    "downloads": {
      "enabled": false,
      "defaultDirectory": "$DOCS/kalsaeDemo/Downloads",
      "promptUser": true
    },
    "navigation": {
      "allow": ["ks://localhost/**", "http://localhost:5173/**"],
      "openExternallyOnReject": true
    },
    "secret": {
      "enabled": true,
      "allowedServices": ["api-tokens", "oauth.*"],
      "maxSecretBytes": 65536,
      "allowList": true,
      "allowDelete": true
    },
    "userScripts": {
      "allowOrigins": ["https://app.kalsae", "ks://app"],
      "scripts": [
        {
          "id": "telemetry-boot",
          "path": "scripts/boot.js",
          "injectionTime": "documentStart",
          "forMainFrameOnly": true,
          "origins": ["https://app.kalsae", "ks://app"]
        }
      ]
    }
  },
  "autostart": {
    "args": ["--launched-by-os"]
  },
  "deepLink": {
    "schemes": ["kalsae-demo"],
    "autoRegisterOnLaunch": false
  },
  "tray": {
    "icon": "assets/tray.png",
    "tooltip": "Kalsae Demo",
    "onLeftClick": "tray.toggleMain",
    "menu": [
      { "kind": "action", "id": "show", "label": "Show", "command": "window.showMain" },
      { "kind": "separator" },
      { "kind": "action", "id": "quit", "label": "Quit", "command": "app.quit" }
    ]
  },
  "menu": {
    "appMenu": [
      {
        "kind": "submenu", "id": "file", "label": "File",
        "submenu": [
          { "kind": "action", "id": "new", "label": "New", "accelerator": "CmdOrCtrl+N", "command": "file.new" },
          { "kind": "separator" },
          { "kind": "action", "id": "quit", "label": "Quit", "accelerator": "CmdOrCtrl+Q", "command": "app.quit" }
        ]
      }
    ]
  },
  "notifications": {
    "appUserModelID": "dev.kalsae.demo",
    "defaultIcon": "assets/icon.png"
  },
  "distribution": {
    "target": "developer",
    "appleTeamID": "ABCDE12345",
    "windowsPublisher": "CN=Acme Corp, O=Acme Corp, C=KR",
    "bundleIdentifier": "dev.kalsae.demo"
  },
  "permissions": {
    "camera": { "enabled": false, "reason": "Scan QR codes during onboarding." },
    "microphone": false,
    "photoLibrary": false,
    "location": false,
    "networkServer": false
  },
  "capabilities": {
    "permissions": [
      {
        "identifier": "fs:read",
        "description": "Read project files under $DOCS/kalsaeDemo",
        "commandsAllow": ["fs.readFile", "fs.exists", "fs.listDir"]
      },
      {
        "identifier": "fs:write",
        "description": "Write to user documents",
        "commandsAllow": ["fs.writeFile", "fs.deleteFile"],
        "commandsDeny": ["fs.writeFile.system"]
      },
      {
        "identifier": "app:basic",
        "commandsAllow": ["app.*", "window.*"]
      }
    ],
    "capabilities": [
      {
        "identifier": "main-window",
        "description": "Capabilities available to the main window on desktop platforms",
        "windows": ["main"],
        "permissions": ["fs:read", "fs:write", "app:basic"],
        "platforms": ["windows", "macOS", "linux"]
      },
      {
        "identifier": "settings-window",
        "windows": ["settings-*"],
        "permissions": ["app:basic"]
      },
      {
        "identifier": "trusted-remote",
        "description": "Allow a curated set of trusted https origins to use app:basic",
        "windows": ["main"],
        "permissions": ["app:basic"],
        "local": false,
        "remote": {
          "urls": ["https://*.example.com", "https://docs.example.org"]
        }
      }
    ]
  }
}
